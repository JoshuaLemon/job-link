{
  "ConnectionStrings": {
    "DefaultConnection": "Data Source=JobPlatform.db"
  },

  "Jwt": {
    "Key": "YOUR_REAL_JWT_KEY",
    "Issuer": "JobPlatformAPI",
    "Audience": "JobPlatformClient",
    "DurationInMinutes": 60
  },

  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },

  "Gemini": {
    "ApiKey": "YOUR_REAL_GEMINI_API_KEY"
  },

  "AllowedHosts": "*"
}